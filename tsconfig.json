{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "outDir": "./lib",
    "rootDir": "./src",
    "strict": true,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "isolatedModules": true,
    "lib": ["ESNext"],
    "types": ["node"]
  },
  "exclude": ["node_modules", "**/*.test.ts", "dist", "lib"]
}
